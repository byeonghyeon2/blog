APP_NAME=Tistory IT Blog Writer
DATABASE_URL=sqlite:///./work/blog_writer.db
# MySQL을 사용할 때는 아래처럼 실제 계정 정보로 바꿔주세요.
# 비밀번호에 @, #, %, / 같은 특수문자가 있으면 URL 인코딩이 필요합니다.
# 예: @ -> %40
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/blog?charset=utf8mb4
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
